{%- comment -%}
  Section 3: Stats Bar
  Background: --color-bg-primary (cream)
  3 stat columns, left-aligned numbers (editorial feel)
{%- endcomment -%}

{%- liquid
  assign is_en = false
  if request.locale.iso_code == 'en'
    assign is_en = true
  endif
-%}

<section class="stats-bar bg-primary" aria-label="{% if is_en %}Key statistics{% else %}關鍵數據{% endif %}">
  <div class="container">
    <div class="stats-bar__grid">
      <div class="stats-bar__item animate-on-scroll">
        <span class="stats-bar__number">50,000+</span>
        <span class="stats-bar__label text-overline">{% if is_en %}Bottles Sold{% else %}售出瓶數{% endif %}</span>
      </div>
      <div class="stats-bar__divider" aria-hidden="true"></div>
      <div class="stats-bar__item animate-on-scroll">
        <span class="stats-bar__number">99.9%</span>
        <span class="stats-bar__label text-overline">{% if is_en %}Purity (IFOS Tested){% else %}純度（IFOS檢測）{% endif %}</span>
      </div>
      <div class="stats-bar__divider" aria-hidden="true"></div>
      <div class="stats-bar__item animate-on-scroll">
        <span class="stats-bar__number">{% if is_en %}5-Star{% else %}5星{% endif %}</span>
        <span class="stats-bar__label text-overline">{% if is_en %}IFOS International Rating{% else %}IFOS國際認證評級{% endif %}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homega Stats Bar",
  "tag": "div",
  "class": "homega-stats-bar-wrapper"
}
{% endschema %}
