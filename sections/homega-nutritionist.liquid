{%- comment -%}
  Section 7: Nutritionist's Perspective + Quality Standards
  Background: --color-bg-dark (dark charcoal) — THE one dark section
  Split: left = Arlene's video + pull quote; right = certification stack
{%- endcomment -%}

{%- liquid
  assign is_en = false
  if request.locale.iso_code == 'en'
    assign is_en = true
  endif
-%}

<section class="nutritionist bg-dark section-padding" aria-labelledby="nutritionist-heading">
  <div class="container">
    <p class="text-overline nutritionist__overline">
      {% if is_en %}A NUTRITIONIST'S PERSPECTIVE{% else %}營養師的專業分析{% endif %}
    </p>

    <h2 id="nutritionist-heading">
      {% if is_en %}A Nutritionist's Perspective{% else %}營養師的專業分析{% endif %}
    </h2>

    <div class="nutritionist__grid">
      {%- comment -%} Left column: Video + Pull quote {%- endcomment -%}
      <div class="nutritionist__video-col">
        <div class="nutritionist__video-wrapper">
          {%- comment -%}
            Video embed: Arlene Q&A
            File: ~/Downloads/20250611 - HMG - 營養師QnA v2.mp4
            This should be uploaded to Shopify Files or an external host.
            Using HTML5 video with poster frame for performance.
            Subtitles: EN track pending (Open Items)
          {%- endcomment -%}
          <video
            class="nutritionist__video"
            controls
            preload="metadata"
            playsinline
            width="640"
            height="360"
            poster=""
          >
            {%- comment -%}
              Replace src with the hosted video URL after upload.
              Add <track> for EN subtitles when available.
            {%- endcomment -%}
            <source src="" type="video/mp4">
            {% if is_en %}Your browser does not support the video tag.{% else %}你的瀏覽器不支援影片播放。{% endif %}
          </video>
          <p class="nutritionist__attribution text-small">
            {% if is_en %}Arlene Wu (伍雅芬) · Nutritionist · UK-Certified Vegetarian Nutrition Therapist · Author of《素身主義》{% else %}伍雅芬（Arlene Wu）· 營養學家 · 英國認證素食營養治療師 · 《素身主義》作者{% endif %}
          </p>
        </div>

        {%- comment -%} Pull quote {%- endcomment -%}
        <blockquote class="nutritionist__quote">
          <p>
            {% if is_en %}"Quality certifications are essential for fish oil safety. HOMEGA carries QualitySilver, IFOS, and FDA certifications — all top-tier international quality standards, proving it has passed rigorous quality controls."{% else %}「品質認證對魚油產品的安全性十分重要。HOMEGA魚油有齊QualitySilver、IFOS和FDA的認證，都是國際頂尖的品質認證，證明了HOMEGA魚油已經通過所有嚴格的質量控制。」{% endif %}
          </p>
          <footer class="nutritionist__quote-footer">
            <cite>{% if is_en %}— Arlene Wu, Nutritionist{% else %}— 伍雅芬，營養學家{% endif %}</cite>
          </footer>
        </blockquote>
      </div>

      {%- comment -%} Right column: Certification stack {%- endcomment -%}
      <div class="nutritionist__certs-col">
        <h3 class="nutritionist__certs-heading">
          {% if is_en %}Internationally Certified · Quality Assured{% else %}國際認證 · 品質保證{% endif %}
        </h3>

        <div class="cert-stack">
          {%- comment -%} IFOS 5-Star {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="16" text-anchor="middle" fill="var(--color-secondary)" font-size="8" font-weight="600">IFOS</text>
                <text x="20" y="28" text-anchor="middle" fill="var(--color-secondary)" font-size="10" font-weight="700">★★★★★</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>IFOS 5{% if is_en %}-Star{% else %}星{% endif %}</strong>
              <p class="text-small">{% if is_en %}International Fish Oil Standards — highest rating. Independent third-party testing of purity, potency, and freshness.{% else %}國際魚油標準認證，最高評級。獨立第三方檢測純度、效力及新鮮度。{% endif %}</p>
            </div>
          </div>

          {%- comment -%} QualitySilver {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="4" y="4" width="32" height="32" rx="4" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="24" text-anchor="middle" fill="var(--color-secondary)" font-size="7" font-weight="600">QS</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>QualitySilver</strong>
              <p class="text-small">{% if is_en %}Omegavie's proprietary stabilization technology. 3x the oxidative stability of standard fish oil.{% else %}Omegavie專利穩定技術，穩定性為市場同類產品的3倍。{% endif %}</p>
            </div>
          </div>

          {%- comment -%} USFDA {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="4" y="4" width="32" height="32" rx="4" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="24" text-anchor="middle" fill="var(--color-secondary)" font-size="8" font-weight="600">FDA</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>USFDA</strong>
              <p class="text-small">{% if is_en %}Approved by the United States Food and Drug Administration.{% else %}美國食品及藥物管理局批準。{% endif %}</p>
            </div>
          </div>

          {%- comment -%} GOED {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="24" text-anchor="middle" fill="var(--color-secondary)" font-size="8" font-weight="600">GOED</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>GOED</strong>
              <p class="text-small">{% if is_en %}Global Organization for EPA and DHA Omega-3s member. Meets international purity standards.{% else %}國際Omega-3濃縮魚油組織成員，符合國際純度標準。{% endif %}</p>
            </div>
          </div>

          {%- comment -%} GMP + HACCP {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="4" y="4" width="32" height="32" rx="4" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="20" text-anchor="middle" fill="var(--color-secondary)" font-size="7" font-weight="600">GMP</text>
                <text x="20" y="30" text-anchor="middle" fill="var(--color-secondary)" font-size="6" font-weight="600">HACCP</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>GMP + HACCP</strong>
              <p class="text-small">{% if is_en %}Manufactured in certified facilities meeting international pharmaceutical-grade quality controls.{% else %}於認證工廠生產，符合國際製藥級品質管控。{% endif %}</p>
            </div>
          </div>

          {%- comment -%} NPRA {%- endcomment -%}
          <div class="cert-item">
            <div class="cert-item__badge" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="4" y="4" width="32" height="32" rx="4" stroke="var(--color-secondary)" stroke-width="2"/>
                <text x="20" y="22" text-anchor="middle" fill="var(--color-secondary)" font-size="7" font-weight="600">NPRA</text>
              </svg>
            </div>
            <div class="cert-item__text">
              <strong>NPRA</strong>
              <p class="text-small">{% if is_en %}Registered with Malaysia's National Pharmaceutical Regulatory Agency. MAL19096038NC.{% else %}馬來西亞國家藥品管理局註冊。MAL19096038NC。{% endif %}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homega Nutritionist",
  "tag": "div",
  "class": "homega-nutritionist-wrapper"
}
{% endschema %}
