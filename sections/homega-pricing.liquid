{%- comment -%}
  Section 8: Pricing / Bundles
  Background: --color-bg-primary (cream)
  3 pricing cards, middle (3 boxes) highlighted
  Mobile: stack vertically, recommended on top (CSS reorder)
{%- endcomment -%}

{%- liquid
  assign is_en = false
  if request.locale.iso_code == 'en'
    assign is_en = true
  endif
-%}

<section id="pricing" class="pricing bg-primary section-padding" aria-labelledby="pricing-heading">
  <div class="container">
    <p class="text-overline pricing__overline">
      {% if is_en %}CHOOSE YOUR PLAN{% else %}選擇你的方案{% endif %}
    </p>

    <h2 id="pricing-heading">
      {% if is_en %}Choose Your Plan{% else %}選擇你的方案{% endif %}
    </h2>

    <p class="pricing__subtitle">
      {% if is_en %}Each box contains 60 softgel capsules (approximately 30-day supply at 2 capsules per day).{% else %}每盒60粒軟膠囊（約30日用量，以每日2粒計算）{% endif %}
    </p>

    <div class="pricing__grid">
      {%- comment -%} Card 1: 1 Box {%- endcomment -%}
      <article class="pricing-card animate-on-scroll">
        <div class="pricing-card__header">
          <h3 class="pricing-card__title">{% if is_en %}1 Box{% else %}1盒{% endif %}</h3>
          <p class="pricing-card__capsules text-small">60 {% if is_en %}capsules{% else %}粒{% endif %}</p>
        </div>
        <div class="pricing-card__price">
          <span class="pricing-card__currency">HK$</span>
          <span class="pricing-card__amount">700</span>
        </div>
        <div class="pricing-card__details">
          <p class="pricing-card__per-box">HK$700{% if is_en %}/box{% else %}/盒{% endif %}</p>
          <p class="pricing-card__per-day text-small">HK$23.33{% if is_en %}/day{% else %}/日{% endif %}</p>
        </div>
        <div class="pricing-card__shipping">
          <span class="pricing-card__shipping-free">{% if is_en %}Free Shipping{% else %}免運費{% endif %}</span>
        </div>
        <a href="#" class="btn-cta pricing-card__cta" data-variant-id="">
          {% if is_en %}Add to Cart{% else %}加入購物車{% endif %}
        </a>
      </article>

      {%- comment -%} Card 2: 3 Boxes (Recommended) {%- endcomment -%}
      <article class="pricing-card pricing-card--recommended animate-on-scroll">
        <span class="pricing-card__badge">{% if is_en %}MOST POPULAR{% else %}最受歡迎{% endif %}</span>
        <div class="pricing-card__header">
          <h3 class="pricing-card__title">{% if is_en %}3 Boxes{% else %}3盒{% endif %}</h3>
          <p class="pricing-card__capsules text-small">180 {% if is_en %}capsules{% else %}粒{% endif %}</p>
          <p class="pricing-card__plan-label text-small">{% if is_en %}Starter{% else %}基本配套{% endif %}</p>
        </div>
        <div class="pricing-card__price">
          <span class="pricing-card__currency">HK$</span>
          <span class="pricing-card__amount">1,650</span>
        </div>
        <div class="pricing-card__details">
          <p class="pricing-card__per-box">HK$550{% if is_en %}/box{% else %}/盒{% endif %}</p>
          <p class="pricing-card__per-day text-small">HK$18.33{% if is_en %}/day{% else %}/日{% endif %}</p>
          <p class="pricing-card__savings">{% if is_en %}Save HK$450{% else %}節省HK$450{% endif %}</p>
        </div>
        <div class="pricing-card__shipping">
          <span class="pricing-card__shipping-free">{% if is_en %}Free Shipping{% else %}免運費{% endif %}</span>
        </div>
        <a href="#" class="btn-cta pricing-card__cta" data-variant-id="">
          {% if is_en %}Add to Cart{% else %}加入購物車{% endif %}
        </a>
      </article>

      {%- comment -%} Card 3: 6 Boxes {%- endcomment -%}
      <article class="pricing-card animate-on-scroll">
        <div class="pricing-card__header">
          <h3 class="pricing-card__title">{% if is_en %}6 Boxes{% else %}6盒{% endif %}</h3>
          <p class="pricing-card__capsules text-small">360 {% if is_en %}capsules{% else %}粒{% endif %}</p>
          <p class="pricing-card__plan-label text-small">{% if is_en %}Full Program{% else %}完整方案{% endif %}</p>
        </div>
        <div class="pricing-card__price">
          <span class="pricing-card__currency">HK$</span>
          <span class="pricing-card__amount">3,000</span>
        </div>
        <div class="pricing-card__details">
          <p class="pricing-card__per-box">HK$500{% if is_en %}/box{% else %}/盒{% endif %}</p>
          <p class="pricing-card__per-day text-small">HK$16.67{% if is_en %}/day{% else %}/日{% endif %}</p>
          <p class="pricing-card__savings">{% if is_en %}Save HK$1,200{% else %}節省HK$1,200{% endif %}</p>
        </div>
        <div class="pricing-card__shipping">
          <span class="pricing-card__shipping-free">{% if is_en %}Free Shipping{% else %}免運費{% endif %}</span>
        </div>
        <a href="#" class="btn-cta pricing-card__cta" data-variant-id="">
          {% if is_en %}Add to Cart{% else %}加入購物車{% endif %}
        </a>
      </article>
    </div>

    <div class="pricing__notes">
      <ul>
        <li>{% if is_en %}Free shipping on all orders — SF Express, 1-2 day delivery{% else %}全單免運費，順豐速遞1-2日送達{% endif %}</li>
        <li>{% if is_en %}We recommend starting with 3 boxes (90 days) to give your body time to respond{% else %}建議首次選購3盒（90日），以完整觀察身體變化{% endif %}</li>
        <li>{% if is_en %}As low as HK$16.67 per day on the 6-box plan — less than a cup of coffee{% else %}每日成本低至HK$16.67（6盒方案），相當於一杯咖啡{% endif %}</li>
      </ul>
    </div>
  </div>
</section>

{%- comment -%} Add to Cart functionality via Shopify Cart API {%- endcomment -%}
<script>
  (function() {
    var pricingCtas = document.querySelectorAll('.pricing-card__cta[data-variant-id]');
    pricingCtas.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var variantId = this.getAttribute('data-variant-id');
        if (!variantId) {
          /* If no variant ID set yet, scroll to Shopify product form as fallback */
          window.location.href = '#pricing';
          return;
        }
        var originalText = this.textContent;
        this.textContent = '...';
        this.style.pointerEvents = 'none';

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
        })
        .then(function(res) { return res.json(); })
        .then(function() {
          window.location.href = '/cart';
        })
        .catch(function() {
          btn.textContent = originalText;
          btn.style.pointerEvents = '';
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Homega Pricing",
  "tag": "div",
  "class": "homega-pricing-wrapper"
}
{% endschema %}
