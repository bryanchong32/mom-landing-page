{%- comment -%}
  Section 2: Utility Trust Bar
  Background: --color-bg-secondary (ivory)
  Horizontal scroll on mobile, 3 trust items
{%- endcomment -%}

{%- liquid
  assign is_en = false
  if request.locale.iso_code == 'en'
    assign is_en = true
  endif
-%}

<section class="trust-bar bg-secondary" aria-label="{% if is_en %}Trust indicators{% else %}信譽保證{% endif %}">
  <div class="trust-bar__inner">
    <ul class="trust-bar__list">
      <li class="trust-bar__item">
        {%- comment -%} Shipping truck icon {%- endcomment -%}
        <svg class="trust-bar__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13" rx="1"/>
          <path d="M16 8h4l3 3v5h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
        <span>{% if is_en %}HK Warehouse · SF Express 1-2 Day Delivery · Free Shipping on All Orders{% else %}香港倉直送 · 順豐1-2日送達 · 全單免運費{% endif %}</span>
      </li>
      <li class="trust-bar__divider" aria-hidden="true"></li>
      <li class="trust-bar__item">
        {%- comment -%} Shield/certificate icon {%- endcomment -%}
        <svg class="trust-bar__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <span>{% if is_en %}IFOS 5-Star · Third-Party Tested{% else %}IFOS 5星 · 第三方檢測{% endif %}</span>
      </li>
      <li class="trust-bar__divider" aria-hidden="true"></li>
      <li class="trust-bar__item">
        {%- comment -%} Guarantee badge icon {%- endcomment -%}
        <svg class="trust-bar__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="7"/>
          <path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/>
          <path d="M9.5 8l1 1.5L14 7"/>
        </svg>
        <span>{% if is_en %}Quality Guaranteed · NPRA Registered{% else %}品質保證 · NPRA註冊{% endif %}</span>
      </li>
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Homega Trust Bar",
  "tag": "div",
  "class": "homega-trust-bar-wrapper"
}
{% endschema %}
